NODE_ENV=test

# Use um banco exclusivo para testes. Nunca aponte para producao.
TEST_DATABASE_URL=postgresql://uau_test:uau_test@localhost:55433/uau_test?schema=public

JWT_SECRET=test-secret-key-integration
JWT_EXPIRES_IN=8h
ALLOWED_ORIGINS=http://localhost:3001
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=100

ANPR_WEBHOOK_SECRET=test-anpr-secret

ASAAS_ENVIRONMENT=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com
ASAAS_API_KEY=test-asaas-key
ASAAS_WEBHOOK_TOKEN=test-webhook-token
