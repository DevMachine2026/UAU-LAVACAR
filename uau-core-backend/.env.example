NODE_ENV=development
PORT=3000

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.XXXX.supabase.co:5432/postgres

# JWT
JWT_SECRET=troque-por-um-segredo-forte-em-producao
JWT_EXPIRES_IN=8h

# CORS — domínios permitidos (separados por vírgula, sem espaços, sem wildcard)
# Desenvolvimento:
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081
# Produção:
# ALLOWED_ORIGINS=https://admin.uauplus.com,https://app.uauplus.com,https://franqueado.uauplus.com

# Swagger (desabilitar em produção pública)
ENABLE_SWAGGER=true

# Janela do rate limit em MILISSEGUNDOS (ex: 60000 = 60 segundos)
RATE_LIMIT_TTL=60000
RATE_LIMIT_MAX=5

# ANPR / LPR — câmeras de reconhecimento de placa
ANPR_WEBHOOK_SECRET=troque-por-um-segredo-forte-unico

# Asaas (pagamentos) — use sandbox para desenvolvimento
ASAAS_ENVIRONMENT=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com
ASAAS_API_KEY=sua-chave-sandbox-asaas
ASAAS_WEBHOOK_TOKEN=token-secreto-webhook

# E-mail (Resend SMTP) — https://resend.com/docs/send-with-smtp
MAILER_HOST=smtp.resend.com
MAILER_PORT=465
MAILER_USER=resend
MAILER_PASS=re_sua_api_key_resend
MAILER_FROM=noreply@uauplus.com
# MAILER_REJECT_UNAUTHORIZED=true  # padrão: true; defina false APENAS em ambiente local com cert autoassinado

# Super Admin inicial (usado no seed)
SUPER_ADMIN_EMAIL=admin@uauplus.com
# OBRIGATÓRIO para rodar prisma db seed em produção — mínimo 12 caracteres
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_NAME=Super Admin
