NODE_ENV=development
PORT=3000

# Supabase / PostgreSQL
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.XXXX.supabase.co:5432/postgres

# JWT
JWT_SECRET=troque-por-um-segredo-forte-em-producao
JWT_EXPIRES_IN=8h

# CORS — domínios permitidos (separados por vírgula)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8081

# Swagger (desabilitar em produção pública)
ENABLE_SWAGGER=true

# Rate limit
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Asaas (pagamentos) — use sandbox para desenvolvimento
ASAAS_ENVIRONMENT=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com
ASAAS_API_KEY=sua-chave-sandbox-asaas
ASAAS_WEBHOOK_TOKEN=token-secreto-webhook

# E-mail (Resend SMTP) — https://resend.com/docs/send-with-smtp
MAILER_HOST=smtp.resend.com
MAILER_PORT=465
MAILER_USER=resend
MAILER_PASS=re_sua_api_key_resend
MAILER_FROM=noreply@seudominio.com

# Super Admin inicial (usado no seed)
SUPER_ADMIN_EMAIL=admin@uauplus.com
SUPER_ADMIN_PASSWORD=troque-em-producao
SUPER_ADMIN_NAME=Super Admin
