# Base da API NestJS (prefixo global api/v1). Copie para .env na raiz do app.
# O Expo injeta variáveis EXPO_PUBLIC_* em build/dev; app.json não precisa duplicar.
# Desenvolvimento local:
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
# Produção: EXPO_PUBLIC_API_URL=https://api.uauplus.com/api/v1

# DSN do projeto "react-native" na org "uau-plus" do Sentry (Settings > Client Keys (DSN)).
# Opcional: se ausente, o app roda normalmente sem inicializar o Sentry.
EXPO_PUBLIC_SENTRY_DSN=
