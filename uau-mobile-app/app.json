{
  "expo": {
    "name": "UAU+",
    "slug": "uau-mobile-app",
    "scheme": "uau",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": ["expo-router", "expo-secure-store"],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uauplus.mobile"
    },
    "android": {
      "package": "com.uauplus.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0BA95B"
      }
    }
  }
}
