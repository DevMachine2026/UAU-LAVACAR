{
  "expo": {
    "name": "Uau Lava Car+",
    "slug": "uau-mobile-app",
    "scheme": "uauplus",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#009688"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#009688",
          "image": "./assets/splash.png",
          "resizeMode": "cover",
          "android": {
            "backgroundColor": "#009688",
            "image": "./assets/splash-icon-padded.png",
            "resizeMode": "contain",
            "imageWidth": 288
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "uau-plus"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.uauplus.mobile",
      "buildNumber": "3",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.uauplus.mobile",
      "versionCode": 5,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#009688"
      }
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e8c6fc1b-d74f-4b7e-a860-383dd2739f39"
      }
    },
    "owner": "dev-machine"
  }
}
